{
  "name": "use-freshchat",
  "version": "0.1.0",
  "description": "Modern React hooks for Freshchat. TypeScript-first, SSR-safe, Next.js compatible.",
  "type": "module",
  "license": "MIT",
  "author": "ajmalhassan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajmalhassan/use-freshchat.git"
  },
  "homepage": "https://github.com/ajmalhassan/use-freshchat#readme",
  "bugs": {
    "url": "https://github.com/ajmalhassan/use-freshchat/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": ["freshchat", "react", "hooks", "typescript", "freshworks", "live-chat", "widget"]
}
